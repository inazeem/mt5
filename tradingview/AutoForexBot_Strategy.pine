// AutoForexBot Strategy — backtest with session filter + trailing (matches MT5 EAs). Use 15m chart.

//@version=5
strategy("AutoForexBot Strategy", shorttitle="AFB Strat", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     pyramiding=0,
     commission_type=strategy.commission.cash_per_order,
     commission_value=0,
     slippage=1,
     process_orders_on_close=true,
     calc_on_every_tick=true,
     max_labels_count=500)

// ─── Settings ─────────────────────────────────────────────────────────────────
asset = input.string("Auto", "Asset", options=["Auto", "Forex", "Crypto", "Commodity", "Stock", "Index"])

grpRisk = "Risk (MT5 presets)"
usePresetRisk   = input.bool(true, "Use preset TP/SL/trail/session", group=grpRisk)
tpPipsIn        = input.int(25,  "TP (pips/points)", group=grpRisk, minval=1)
slPipsIn        = input.int(15,  "SL (pips/points)", group=grpRisk, minval=1)
trailStartIn    = input.int(10,  "Trail start", group=grpRisk, minval=1)
trailPipsIn     = input.int(8,   "Trail distance", group=grpRisk, minval=1)
trailTpMultIn   = input.float(2.0, "Trail TP multiplier", group=grpRisk, minval=1.0, step=0.1)
sessionStartIn  = input.int(6,   "Session start (UTC hour)", group=grpRisk, minval=0, maxval=23)
sessionEndIn    = input.int(20,  "Session end (UTC hour)", group=grpRisk, minval=0, maxval=23)
closeOnReverse  = input.bool(false, "Close on opposite signal", group=grpRisk)

grpFilt = "Filters"
useSessionFilter = input.bool(true, "Session filter (entries only)", group=grpFilt)
useTrailing      = input.bool(true, "Trailing stop", group=grpFilt)
useTrailTpMult   = input.bool(true, "Widen TP when trail starts", group=grpFilt)

grpPb = "Pullback filter (skip chasing tops/bottoms)"
usePullbackFilter = input.bool(true, "Pullback filter", group=grpPb, tooltip="Only enter after a retrace to the MA zone — avoids buying extended rallies before reversals")
retraceAtrMult    = input.float(0.5, "Retrace touch (ATR x)", group=grpPb, minval=0.1, step=0.1)
maxExtAtrMult     = input.float(1.2, "Max extension (ATR x)", group=grpPb, minval=0.3, step=0.1, tooltip="Block buy if price is too far above slow MA")
rsiBuyMax         = input.float(58.0, "RSI buy max", group=grpPb, minval=40, maxval=70)
rsiSellMin        = input.float(42.0, "RSI sell min", group=grpPb, minval=30, maxval=60)

// ─── Asset detection ──────────────────────────────────────────────────────────
isJpy    = str.contains(syminfo.ticker, "JPY")
isGold   = str.contains(syminfo.ticker, "XAU") or str.contains(syminfo.ticker, "GOLD")
isSilver = str.contains(syminfo.ticker, "XAG") or str.contains(syminfo.ticker, "SILVER")
isOil    = str.contains(syminfo.ticker, "WTI") or str.contains(syminfo.ticker, "BRENT") or str.contains(syminfo.ticker, "OIL")
isIndex  = syminfo.type == "index" or str.contains(syminfo.ticker, "US30") or str.contains(syminfo.ticker, "US500") or str.contains(syminfo.ticker, "NAS") or str.contains(syminfo.ticker, "SPX") or str.contains(syminfo.ticker, "DAX") or str.contains(syminfo.ticker, "UK100")

detected = isIndex ? "Index" : syminfo.type == "crypto" ? "Crypto" : isGold or isSilver or isOil ? "Commodity" : syminfo.type == "forex" ? "Forex" : "Forex"
kind = asset == "Auto" ? detected : asset

float adxFloor = 22.0
float minMove  = 3.0
float pipSize  = isJpy ? 0.01 : 0.0001
int   tpPips   = 25
int   slPips   = 15
int   trailStartPips = 10
int   trailPips = 8
float trailTpMult = 2.0
int   sessionStart = 6
int   sessionEnd = 20

if kind == "Crypto"
    adxFloor := 18.0
    minMove  := 25.0
    pipSize  := 1.0
    tpPips   := 200
    slPips   := 100
    trailStartPips := 50
    trailPips := 50
    trailTpMult := 1.0
    sessionStart := 0
    sessionEnd := 23
else if kind == "Commodity"
    adxFloor := 22.0
    minMove  := 12.0
    pipSize  := 0.01
    tpPips   := 80
    slPips   := 40
    trailStartPips := 30
    trailPips := 15
    trailTpMult := 2.5
    sessionStart := 6
    sessionEnd := 20
else if kind == "Stock" or kind == "Index"
    adxFloor := 22.0
    minMove  := 25.0
    pipSize  := 1.0
    tpPips   := 160
    slPips   := 80
    trailStartPips := 50
    trailPips := 25
    trailTpMult := 3.0
    sessionStart := 14
    sessionEnd := 21

if not usePresetRisk
    tpPips := tpPipsIn
    slPips := slPipsIn
    trailStartPips := trailStartIn
    trailPips := trailPipsIn
    trailTpMult := trailTpMultIn
    sessionStart := sessionStartIn
    sessionEnd := sessionEndIn

tpDist = tpPips * pipSize
slDist = slPips * pipSize
trailStartDist = trailStartPips * pipSize
trailDist = trailPips * pipSize

// ─── Session (UTC) — matches InSessionUtc() in EA ─────────────────────────────
inSessionUtc(startH, endH) =>
    int h = hour(time, "UTC")
    startH <= endH ? (h >= startH and h <= endH) : (h >= startH or h <= endH)

sessionOk = not useSessionFilter or inSessionUtc(sessionStart, sessionEnd)

// ─── Entry logic ──────────────────────────────────────────────────────────────
smaFast = ta.sma(close, 9)
smaSlow = ta.sma(close, 21)
emaFast = ta.ema(close, 9)
emaSlow = ta.ema(close, 21)
[diPlus, diMinus, adxVal] = ta.dmi(14, 14)
atr = ta.atr(14)
rsi = ta.rsi(close, 14)

smaSide = smaFast > smaSlow ? 1 : smaFast < smaSlow ? -1 : 0
emaSide = emaFast > emaSlow ? 1 : emaFast < emaSlow ? -1 : 0
side    = smaSide == emaSide ? smaSide : 0

smaOk = smaSide == 1 ? smaFast[1] > smaSlow[1] : smaSide == -1 ? smaFast[1] < smaSlow[1] : false
emaOk = emaSide == 1 ? emaFast[1] > emaSlow[1] : emaSide == -1 ? emaFast[1] < emaSlow[1] : false
consensusOk = smaOk and emaOk and side != 0

strength = (math.abs(smaFast - smaSlow) + math.abs(emaFast - emaSlow)) / 2.0 / pipSize
adxOk = adxVal[1] >= adxFloor
minMoveOk = strength >= minMove

trendSide(tf) =>
    request.security(syminfo.tickerid, tf, close[1] > open[1] ? 1 : close[1] < open[1] ? -1 : 0, lookahead=barmerge.lookahead_off)

t1 = trendSide("60")
t2 = trendSide("240")
t15 = close[1] > open[1] ? 1 : close[1] < open[1] ? -1 : 0
trendOk(s) => t1 == s and t2 == s and t15 == s

// ─── Pullback detection (buy dips in uptrend, sell rallies in downtrend) ─────
maBandTop = math.max(emaFast, smaFast)
maBandBot = math.min(emaSlow, smaSlow)
retraceBand = atr * retraceAtrMult
extBand = atr * maxExtAtrMult

// Recent retrace: price dipped to fast MA area in last 5 bars
hadRetraceBuy  = ta.lowest(low, 5) <= maBandTop + retraceBand
hadRetraceSell = ta.highest(high, 5) >= maBandBot - retraceBand

// Not chasing: price not over-extended from slow MA
notChasingBuy  = close - smaSlow <= extBand
notChasingSell = smaSlow - close <= extBand

// In the MA ribbon zone (pullback area, not breakout top)
inZoneBuy  = close >= smaSlow and close <= maBandTop + retraceBand
inZoneSell = close <= smaSlow and close >= maBandBot - retraceBand

// RSI recovering from dip / rolling from peak (not overbought/oversold chase)
rsiPullbackBuy  = rsi[1] >= 35 and rsi[1] <= rsiBuyMax and rsi >= rsi[1]
rsiPullbackSell = rsi[1] <= 65 and rsi[1] >= rsiSellMin and rsi <= rsi[1]

// DI confirms trend direction
diBuyOk  = diPlus > diMinus
diSellOk = diMinus > diPlus

pullbackBuyOk  = hadRetraceBuy and notChasingBuy and inZoneBuy and rsiPullbackBuy and diBuyOk
pullbackSellOk = hadRetraceSell and notChasingSell and inZoneSell and rsiPullbackSell and diSellOk
pullbackOk(s) => not usePullbackFilter or (s > 0 ? pullbackBuyOk : pullbackSellOk)

is15m = timeframe.period == "15"
closed = barstate.isconfirmed

buySignal  = closed and is15m and sessionOk and consensusOk and side == 1  and trendOk(1)  and adxOk and minMoveOk and pullbackOk(1)
sellSignal = closed and is15m and sessionOk and consensusOk and side == -1 and trendOk(-1) and adxOk and minMoveOk and pullbackOk(-1)

flat = strategy.position_size == 0
inLong = strategy.position_size > 0
inShort = strategy.position_size < 0
newLong = inLong and not inLong[1]
newShort = inShort and not inShort[1]

// ─── Trailing + TP/SL state (matches ApplyTrailingStops) ─────────────────────
var float longStop = na
var float longLimit = na
var bool  longTpWidened = false
var float shortStop = na
var float shortLimit = na
var bool  shortTpWidened = false

if flat
    longStop := na
    longLimit := na
    longTpWidened := false
    shortStop := na
    shortLimit := na
    shortTpWidened := false

if newLong
    longStop := na
    longLimit := na
    longTpWidened := false
if newShort
    shortStop := na
    shortLimit := na
    shortTpWidened := false

// ─── Entries ──────────────────────────────────────────────────────────────────
if closeOnReverse and sellSignal and inLong
    strategy.close("Long", comment="Reverse")
if closeOnReverse and buySignal and inShort
    strategy.close("Short", comment="Reverse")

canLong  = buySignal  and (flat or (closeOnReverse and not inLong))
canShort = sellSignal and (flat or (closeOnReverse and not inShort))

if canLong
    strategy.entry("Long", strategy.long, comment="BUY")
if canShort
    strategy.entry("Short", strategy.short, comment="SELL")

// ─── Exits: initial SL/TP then trail (EA runs every tick; we update each calc) ─
if inLong
    float avg = strategy.position_avg_price
    float profitDist = close - avg
    if na(longStop)
        longStop := avg - slDist
    if na(longLimit)
        longLimit := avg + tpDist
    if useTrailing and profitDist >= trailStartDist
        float trailSl = close - trailDist
        longStop := math.max(longStop, trailSl)
        if useTrailTpMult and not longTpWidened and trailTpMult > 1.0
            longLimit := avg + tpDist * trailTpMult
            longTpWidened := true
    strategy.exit("Long Exit", "Long", stop=longStop, limit=longLimit)

if inShort
    float avg = strategy.position_avg_price
    float profitDist = avg - close
    if na(shortStop)
        shortStop := avg + slDist
    if na(shortLimit)
        shortLimit := avg - tpDist
    if useTrailing and profitDist >= trailStartDist
        float trailSl = close + trailDist
        shortStop := math.min(shortStop, trailSl)
        if useTrailTpMult and not shortTpWidened and trailTpMult > 1.0
            shortLimit := avg - tpDist * trailTpMult
            shortTpWidened := true
    strategy.exit("Short Exit", "Short", stop=shortStop, limit=shortLimit)

// ─── Visuals ──────────────────────────────────────────────────────────────────
signalLine = (emaFast + smaFast) / 2.0
plot(signalLine, "Signal line", color=color.yellow, linewidth=2)
plot(inLong ? longStop : inShort ? shortStop : na, "Active SL", color=color.new(color.red, 30), style=plot.style_linebr, linewidth=1)
plot(inLong ? longLimit : inShort ? shortLimit : na, "Active TP", color=color.new(color.lime, 30), style=plot.style_linebr, linewidth=1)
plotshape(canLong and flat,  title="Buy",  style=shape.labelup,   location=location.belowbar, color=color.lime, text="BUY",  textcolor=color.black, size=size.small)
plotshape(canShort and flat, title="Sell", style=shape.labeldown, location=location.abovebar, color=color.red,  text="SELL", textcolor=color.white, size=size.small)
bgcolor(usePullbackFilter and consensusOk and side == 1 and not pullbackBuyOk ? color.new(color.orange, 88) : usePullbackFilter and consensusOk and side == -1 and not pullbackSellOk ? color.new(color.orange, 88) : not sessionOk and useSessionFilter ? color.new(color.gray, 90) : na, title="Filtered / session")
